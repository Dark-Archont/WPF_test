<Window x:Class="SmartMealWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmartMealWpf.ViewModels"
        mc:Ignorable="d"
        Title="Тестовое WPF-приложение для SmartMealService"
        Height="450" Width="800"
        MinHeight="350" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5DC">

    <Window.Resources>
        <!-- Column header style to match the mockup -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Cell style for consistent padding -->
        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row style -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F7FBFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border CornerRadius="10"
                BorderBrush="#AAAAAA"
                BorderThickness="1.5"
                Background="White">
            <DataGrid x:Name="EnvVarGrid"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionUnit="Cell"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0E0E0"
                      BorderThickness="0"
                      Background="White"
                      RowHeaderWidth="28"
                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                      CellStyle="{StaticResource CellStyle}"
                      RowStyle="{StaticResource RowStyle}"
                      CellEditEnding="EnvVarGrid_CellEditEnding"
                      Margin="0">

                <DataGrid.Columns>
                    <!-- Поле: read-only, name from config -->
                    <DataGridTextColumn Header="Поле"
                                        Binding="{Binding Name, Mode=OneWay}"
                                        Width="2*"
                                        IsReadOnly="True"/>

                    <!-- Значение: editable -->
                    <DataGridTextColumn Header="Значение"
                                        Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="3*"
                                        IsReadOnly="False"/>

                    <!-- Комментарий: editable, user notes -->
                    <DataGridTextColumn Header="Комментарий"
                                        Binding="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="3*"
                                        IsReadOnly="False"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
